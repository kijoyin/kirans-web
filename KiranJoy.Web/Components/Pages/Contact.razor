@page "/contact"

<section class="section">
    <H1>Contact</H1>
    <p class="lead-block" style="margin-top:1rem;">
        The best way to reach me is email or LinkedIn. I'm always happy to talk integration,
        .NET, cloud architecture, or AI.
    </p>

    <div class="cta-row">
        <a class="btn btn-primary" href="mailto:@WebsiteKeys.Email">
            <Svg Icon="Svg.Icons.Mail" /> Email me
        </a>
        <a class="btn btn-ghost" href="@WebsiteKeys.LinkedIn" target="_blank" rel="noopener noreferrer">
            <Svg Icon="Svg.Icons.LinkedIn" /> LinkedIn
        </a>
        <a class="btn btn-ghost" href="@WebsiteKeys.GitHub" target="_blank" rel="noopener noreferrer">
            <Svg Icon="Svg.Icons.Github" /> GitHub
        </a>
    </div>
</section>
