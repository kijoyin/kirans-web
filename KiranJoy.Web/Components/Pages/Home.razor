@page "/"
@using BlazorStatic
@using BlazorStatic.Services
@inject BlazorStaticContentService<BlogFrontMatter> blazorStaticContentService

@* =========================================================================
   HOME / RESUME
   Edit the copy below to match your story. Placeholders marked TODO.
   ========================================================================= *@

<section class="hero">
    <div class="hero-grid">
        <img class="hero-avatar" src="/img/kiran-joy.jpg" alt="Portrait of @WebsiteKeys.Name" width="190" height="190" />
        <div class="hero-text">
            <h1>@WebsiteKeys.Name</h1>
            <p class="lead">Software Engineering Manager &amp; Integration Architect — building resilient .NET systems and secure cloud integrations, and leading teams into applied AI.</p>
            <p class="intro">
                Based in Brisbane, Australia, I help organisations connect complex systems and ship dependable
                software at scale. My focus is enterprise integration, secure .NET services and API platforms across
                AWS and Azure, and pragmatic adoption of AI. I care about developer experience, clean architecture,
                and mentoring engineers to do their best work.
            </p>
            <div class="cta-row">
                <a class="btn btn-primary" href="/blog">Read the blog</a>
                <a class="btn btn-ghost" href="@WebsiteKeys.LinkedIn" target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a>
                <a class="btn btn-ghost" href="mailto:@WebsiteKeys.Email">Get in touch</a>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <h2 class="section-title">What I do</h2>
    <ul class="pill-list">
        <li class="pill">Enterprise Integration</li>
        <li class="pill">.NET / C#</li>
        <li class="pill">AWS</li>
        <li class="pill">Azure</li>
        <li class="pill">REST APIs &amp; Platforms</li>
        <li class="pill">Microservices</li>
        <li class="pill">Messaging (IBM MQ)</li>
        <li class="pill">Elasticsearch / ELK</li>
        <li class="pill">Kubernetes</li>
        <li class="pill">Sitecore DXP</li>
        <li class="pill">DevOps &amp; CI/CD</li>
        <li class="pill">Applied AI / LLMs</li>
        <li class="pill">Engineering Leadership</li>
    </ul>
</section>

<section class="section">
    <h2 class="section-title">Experience</h2>
    <ol class="timeline">
        <li class="timeline-item">
            <div class="period">Dec 2021 — Present</div>
            <div>
                <h3>Software Engineering Manager</h3>
                <div class="org">Avanade · Queensland, Australia</div>
                <p>
                    Architect and deliver enterprise-grade counter-fraud and risk-detection solutions for a
                    major federal organisation — complex multi-account AWS integrations, secure .NET services,
                    API platforms and multi-factor data replication. Serve as Integration Architect and Product
                    Owner across two agile teams while staying hands-on in cloud architecture and solution design.
                    Also led the end-to-end delivery of a reusable multi-source content migration platform for
                    Sitecore DXP, onboarding content from legacy CMS, SharePoint 2013 and SharePoint Online.
                </p>
            </div>
        </li>
        <li class="timeline-item">
            <div class="period">Sep 2015 — Dec 2021</div>
            <div>
                <h3>Senior Consultant</h3>
                <div class="org">Avanade · Queensland, Australia</div>
                <p>
                    Integration specialist for a government organisation. Designed and built RESTful APIs
                    connecting client apps to backend systems including IBM WebSphere MQ, Elasticsearch and
                    SQL Server. Implemented an ELK (Elasticsearch, Logstash, Kibana) stack to monitor and
                    triage issues across ~40 development environments.
                </p>
            </div>
        </li>
        <li class="timeline-item">
            <div class="period">Nov 2012 — Sep 2015</div>
            <div>
                <h3>Senior Technical Developer</h3>
                <div class="org">Reading Room · Fortitude Valley, QLD</div>
                <p>
                    Delivered Sitecore and Umbraco projects using .NET, C# and JavaScript, integrating
                    Google Maps and the Twitter, Facebook, Tumblr and Flickr APIs.
                </p>
            </div>
        </li>
        <li class="timeline-item">
            <div class="period">Jul 2012 — Nov 2012</div>
            <div>
                <h3>Analyst Programmer</h3>
                <div class="org">Shortcuts Software · Fortitude Valley, Brisbane</div>
                <p>
                    Designed and developed web solutions, translated client requirements into delivery,
                    and mentored junior developers.
                </p>
            </div>
        </li>
        <li class="timeline-item">
            <div class="period">Mar 2011 — Jul 2012</div>
            <div>
                <h3>Web Developer</h3>
                <div class="org">BMT WBM · Brisbane</div>
                <p>
                    Built a web-based image and media library with ASP.NET 4 (C#), HTML, jQuery, CSS3 and
                    SQL Server, and acted as webmaster for company websites.
                </p>
            </div>
        </li>
        <li class="timeline-item">
            <div class="period">Feb 2010 — Apr 2011</div>
            <div>
                <h3>Web Application Developer</h3>
                <div class="org">Tyco Water · Wacol, QLD</div>
                <p>
                    Built a web application automating contractor registration, online induction and approval —
                    live from November 2010. Began as a Master of IT project and grew with further features.
                </p>
            </div>
        </li>
    </ol>
</section>

<section class="section">
    <h2 class="section-title">Speaking &amp; Community</h2>
    <ul class="timeline">
        <li class="timeline-item">
            <div class="period">2023</div>
            <div>
                <h3>Home Labs — Why every developer should build one</h3>
                <div class="org">DDD Brisbane</div>
                <p>A talk on using a home lab to accelerate learning for developers and DevOps engineers.</p>
            </div>
        </li>
    </ul>
</section>

@if (blazorStaticContentService.Posts.Any())
{
    <section class="section">
        <h2 class="section-title">Latest writing</h2>
        <PostsList Posts="latest" />
        <a class="read-more" href="/blog">View all posts →</a>
    </section>
}

@code {
    List<Post<BlogFrontMatter>> latest = new();

    protected override void OnInitialized()
    {
        latest = blazorStaticContentService.Posts
            .OrderByDescending(p => p.FrontMatter.Published)
            .Take(3)
            .ToList();
    }
}
