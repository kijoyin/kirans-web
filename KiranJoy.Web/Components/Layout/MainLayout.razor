@inherits LayoutComponentBase

<div class="page">
    <NavMenu/>

    <main class="site-main">
        <div class="container">
            @Body
        </div>
    </main>

    <footer class="site-footer">
        <div class="container footer-inner">
            <div class="footer-social">
                <a target="_blank" rel="noopener noreferrer" href="@WebsiteKeys.LinkedIn" aria-label="LinkedIn" data-umami-event="linkedin" data-umami-event-location="footer">
                    <Svg Icon="Svg.Icons.LinkedIn"/>
                </a>
                <a target="_blank" rel="noopener noreferrer" href="@WebsiteKeys.GitHub" aria-label="GitHub" data-umami-event="github" data-umami-event-location="footer">
                    <Svg Icon="Svg.Icons.Github"/>
                </a>
                <a href="mailto:@WebsiteKeys.Email" aria-label="Email" data-umami-event="email" data-umami-event-location="footer">
                    <Svg Icon="Svg.Icons.Mail"/>
                </a>
            </div>
            <div>© @DateTime.Now.Year @WebsiteKeys.Name · Built with Blazor &amp; BlazorStatic</div>
        </div>
    </footer>
</div>

